{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": ["npm install"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["npm run build"],
      "variables": {
        "NODE_ENV": "production",
        "VITE_API_URL": "$VITE_API_URL"
      }
    }
  },
  "deploy": {
    "startCommand": "npx vite preview --port $PORT --host 0.0.0.0",
    "variables": {
      "NODE_ENV": "production",
      "PORT": "5173"
    }
  }
}
