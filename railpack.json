{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": ["npm ci --production=false"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["npm run build"],
      "variables": {
        "NODE_ENV": "production",
        "VITE_API_URL": "$VITE_API_URL"
      }
    }
  },
  "caches": {
    "npm": {
      "path": "/root/.npm"
    }
  },
  "deploy": {
    "startCommand": "npx vite preview --port $PORT --host 0.0.0.0",
    "aptPackages": ["ca-certificates"],
    "variables": {
      "NODE_ENV": "production",
      "PORT": "5173"
    },
    "paths": ["/app/node_modules/.bin"]
  }
}
